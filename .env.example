# Copy this file to `.env.local` and replace the dummy values below.
# All variables defined here are validated at build time by `src/env.ts`.
# All Sentry vars are optional — leave them blank/unset to disable Sentry entirely.

# Public URL of the app (used for absolute URLs, sitemap, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Sentry ---
# Get a DSN from https://sentry.io → Settings → Projects → [your project] → SDK Setup.
# The PUBLIC variant is required for the browser SDK; the server variant for SSR/edge.
NEXT_PUBLIC_SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"

# Sampling rates (0.0 - 1.0). Defaults to 0.1 if unset.
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"
SENTRY_TRACES_SAMPLE_RATE="0.1"

# Source-map upload (only used in CI; set as GitHub repo secrets in production).
SENTRY_AUTH_TOKEN="sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="your-sentry-project"

# --- Phase 4: agentic ⌘K Inspector (all optional) ---
# Without these, `/api/chat` returns a graceful 503 and the Inspector falls
# back to Navigate-only mode. The build script (`pnpm agent:index`) skips
# embeddings without OPENAI_API_KEY and the agent index ships a keyword-only
# tier instead. Set the key locally to author/refresh the embedding index;
# CI does not need it because the committed JSON is the source of truth.
OPENAI_API_KEY="sk-..."
# Override the chat/embedding models. Defaults are the cheapest viable pair
# for grounded RAG against this corpus (~50 chunks).
# OPENAI_CHAT_MODEL="gpt-4o-mini"
# OPENAI_EMBED_MODEL="text-embedding-3-small"

# Rate-limit storage. Without these the route uses an in-memory token bucket
# (per-instance, fine for dev / single-region deployments). Set both to opt
# into a global per-IP limit backed by Upstash Redis.
# UPSTASH_REDIS_REST_URL="https://example.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="A..."

# --- Developer toggles (optional; uncomment as needed) ---
# Enable the bundle analyzer during `pnpm build`.
# ANALYZE="true"

# Skip `src/env.ts` validation (only when you really need to bypass it).
# SKIP_ENV_VALIDATION="1"

# Override the Playwright dev/test server port and base URL.
# PORT="3000"
# PLAYWRIGHT_BASE_URL="http://127.0.0.1:3000"
