{
  "name": "diogo-studio",
  "version": "1.3.0",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "predev": "velite",
    "prebuild": "velite && pnpm agent:index:check",
    "pretest": "velite",
    "pretest:coverage": "velite",
    "pretypecheck": "velite",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "content": "velite",
    "content:watch": "velite --watch",
    "agent:index": "tsx scripts/build-agent-index.ts",
    "agent:index:check": "tsx scripts/build-agent-index.ts --check",
    "analyze": "ANALYZE=true next build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install --with-deps",
    "preknip": "velite",
    "knip": "knip",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "validate": "pnpm lint && pnpm typecheck && pnpm format:check && pnpm test && pnpm knip",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.68",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@react-email/components": "^1.0.12",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@sentry/nextjs": "^10.55.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.190",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lenis": "^1.3.23",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.77.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "shiki": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "three": "^0.182.0",
    "vaul": "^1.1.2",
    "velite": "^0.3.1",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@size-limit/file": "^12.1.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.15.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "schema-dts": "^2.0.0",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6",
    "vitest": "^4.1.7"
  }
}
