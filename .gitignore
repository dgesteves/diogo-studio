# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/.vitest-cache

# playwright
/playwright-report
/test-results
/blob-report
/playwright/.cache

# lighthouse local reports
/lighthouse-*.json
/lighthouse-*.html

# next.js
/.next/
/out/

# velite — generated content output (committed types live in src; data is built)
/.velite/
/public/static/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
